---
import Scripts from "../components/Scripts.astro";
interface Props {
	title: string;
}

const { title } = Astro.props;

const levels = [
	{ level: 1, label: 'Colours', href: '/' },
	{ level: 2, label: '2D shapes', href: '/level/2' },
	{ level: 3, label: '3D shapes', href: '/level/3' },
	{ level: 4, label: '2D + 3D', href: '/level/4' },
	{ level: 5, label: 'Coloured 2D', href: '/level/5' },
	{ level: 6, label: 'Coloured 3D', href: '/level/6' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<Scripts />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="bg-logo">
			<div class="flex-1 h-full flex items-center justify-center">
				<h1 class="text-xl font-semibold">Voice Guessing Game</h1>
			</div>
			<button class="nav-toggle flex md:hidden before:flex before:hidden" aria-label="Mobile Menu">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
			<nav class="relative" aria-label="Difficulty levels">
				<ul class="nav-menu my-2 flex hidden md:flex flex-col items-start md:flex-row md:justify-center md:gap-6 lg:gap-8">
					{levels.map(({ level, label, href }) => (
						<li>
							<a href={href} class="nav-link block py-2 px-1 focus:ring-2 focus:ring-offset-2 rounded" aria-label={`Level ${level}: ${label}`}>
								{level}. {label}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</header>
		<slot />
	</body>
</html>
<style is:global>
	@font-face {
		font-family: 'Roboto';
		src: url('/fonts/Roboto-Regular.ttf') format('truetype');
		font-style: normal;
		font-weight: 400;
		font-display: swap;
	}
	:root {
		--logo-bg: #92bdd0;
		--logo-color: #05202e;
		--xs: 375px;
		--sm: 576px;
		--md: 960px;
		--lg: 1440px;
		--xl: 1536px;
	}
	html {
		font-family: 'Roboto' , system-ui, sans-serif;
		background: #13151a;
		background-size: 224px;
	}
	body {
		display: grid;
	    grid-template-rows: auto 1fr auto;
	}
	h1 {
		font-size: 2.5rem;
	}
	h2 {
		font-size: 1.8rem;
	}
	h3 {
		font-size: 1.6rem;
	}
	h4 {
		font-size: 1.4rem;
	}
	h5 {
		font-size: 1.2rem;
	}
	header {
		min-height: 2rem;
		color: var(--logo-color);
		position: fixed;
		width: 100%;
		max-width: var(--lg);
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		display: grid;
		grid-template-rows: 1fr;
		grid-template-columns: 50px 1fr;
		align-items: center;
		justify-items: center;
		text-align: center;
		& .nav-toggle {
			grid-column-start: 3;
			height: 48px;
			width: 48px;
			justify-content: center;
			align-items: center;
			&::before {
				content: "";
				background-color: var(--logo-bg);
				background-image: url(../images/x-icon.svg);
				background-size: 24px;
				background-repeat: no-repeat;
				background-position: center;
				position: absolute;
				height: 48px;
				width: 48px;

			}
		}
		& nav {
			width: 100%;
			grid-column: 1 / span 3;
			& .nav-menu li {
				width: 100%;
				a {
					display: block;
					position: relative;
					width: 100%;
					height: 100%;
					padding-right: 1.5rem;
					min-height: 48px;
					min-width: 48px;
					text-align: right;
					z-index: 20;
					@media screen and (min-width: 960px) {
						text-align: center;
						&::before {
							content: "";
							position: absolute;
							background-color: var(--wenge);
							bottom: 0;
							width: 2rem;
							height: 3px;
							z-index: -1;
							transition: all 0.3s;
						}
						&:hover, &:focus {
							&::before {
								background-color: var(--cordovan);
								width: 70%;
								height: 2px;

							}
						}
					}	
				}
			} 
		}
	}
	main {
		min-height: calc(100vh - 2rem);
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		gap: 1rem;
	}
	footer {
		min-height: 2rem;
	}
</style>

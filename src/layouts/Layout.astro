---
import Scripts from "../components/Scripts.astro";
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<Scripts />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	@font-face {
		font-family: 'Roboto';
		src: url('/fonts/Roboto-Regular.ttf') format('truetype');
		font-style: normal;
		font-weight: 400;
		font-display: swap;
	}
	:root {
		--logo-bg: #92bdd0;
		--logo-color: #05202e;
		--xs: 375px;
		--sm: 576px;
		--md: 960px;
		--lg: 1440px;
		--xl: 1536px;
	}
	html {
		font-family: 'Roboto' , system-ui, sans-serif;
		background: #13151a;
		background-size: 224px;
	}
	body {
		display: grid;
	    grid-template-rows: auto 1fr auto;
	}
	h1 {
		font-size: 2.5rem;
	}
	h2 {
		font-size: 1.8rem;
	}
	h3 {
		font-size: 1.6rem;
	}
	h4 {
		font-size: 1.4rem;
	}
	h5 {
		font-size: 1.2rem;
	}
	header {
		min-height: 2rem;
		color: var(--logo-color);
		position: fixed;
		width: 100%;
		max-width: var(--lg);
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		display: grid;
		grid-template-rows: 1fr;
		grid-template-columns: 50px 1fr;
		align-items: center;
		justify-items: center;
		text-align: center;
		& .nav-toggle {
			grid-column-start: 3;
			height: 48px;
			width: 48px;
			justify-content: center;
			align-items: center;
			&::before {
				content: "";
				background-color: var(--logo-bg);
				background-image: url(../images/x-icon.svg);
				background-size: 24px;
				background-repeat: no-repeat;
				background-position: center;
				position: absolute;
				height: 48px;
				width: 48px;

			}
		}
		& nav {
			width: 100%;
			grid-column: 1 / span 3;
			& .nav-menu li {
				width: 100%;
				a {
					display: block;
					position: relative;
					width: 100%;
					height: 100%;
					padding-right: 1.5rem;
					min-height: 48px;
					min-width: 48px;
					text-align: right;
					z-index: 20;
					@media screen and (min-width: 960px) {
						text-align: center;
						&::before {
							content: "";
							position: absolute;
							background-color: var(--wenge);
							bottom: 0;
							width: 2rem;
							height: 3px;
							z-index: -1;
							transition: all 0.3s;
						}
						&:hover, &:focus {
							&::before {
								background-color: var(--cordovan);
								width: 70%;
								height: 2px;

							}
						}
					}	
				}
			} 
		}
	}
	main {
		min-height: calc(100vh - 2rem);
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		gap: 1rem;
	}
	footer {
		min-height: 2rem;
	}
</style>
